# LangWatch local stack config (copy to langwatch/.env; that copy is gitignored).
# SKIP_ENV_VALIDATION=true in compose.yml lets the app boot with minimal config;
# these are the few values a local single user instance still wants. Change the
# secret for anything beyond a throwaway local instance.

# Session signing secret for the local app. Any long random string.
NEXTAUTH_SECRET=payflow-local-dev-change-me

# Base URL the app serves itself on locally.
BASE_HOST=http://localhost:5560
NEXTAUTH_URL=http://localhost:5560

# Optional: a key for LangWatch's own LLM-backed features (evaluators). The
# PayFlow agent tracing does not need this; leave unset for tracing only.
# OPENAI_API_KEY=
