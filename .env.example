# Copy to .env and fill in. .env is gitignored; never commit real keys.

# Property generation agent (discovery + triage judge). Required for `uv run agent-run`
# and the Layer 2 suite. OpenAI; gpt-5.4-nano by default (agent/config.py).
OPENAI_API_KEY=sk-proj-...

# Adversarial experiments (e.g. semantic mutation exploration). Anthropic,
# deliberately a different model family than the OpenAI proposer so the adversary
# does not share the proposer's blind spots. Optional.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: local LangWatch tracing (uv sync --extra observability). Points the OTEL
# exporter at a locally hosted LangWatch; unset means tracing is a no op.
LANGWATCH_ENDPOINT=http://localhost:5560
LANGWATCH_API_KEY=sk-lw-...
